# ═══════════════════════════════════════════════════════════════════
# ORION / DDGK — .env.example (ALLE Platzhalter; echte Werte nur in .env)
# Kopieren nach .env im Repo-Root. Nicht committen.
# Siehe: docs/CURSOR_GITHUB_HF_SETTINGS.md
# ═══════════════════════════════════════════════════════════════════

# --- Hugging Face (Hub, Spaces, API; MCP) ---
# Ein Token reicht; manche Skripte lesen HUGGINGFACE_TOKEN, andere HF_TOKEN
HUGGINGFACE_TOKEN=
HF_TOKEN=
# Ältere HF-CLI-Bezeichnung (falls vorhanden)
HUGGING_FACE_HUB_TOKEN=

# --- GitHub (API, gh CLI, ggf. Actions lokal simulieren) ---
GITHUB_TOKEN=
GH_TOKEN=
GITHUB_PAT=

# --- Zenodo (Skripte lesen meist ZENODO_API_TOKEN; manche INI nutzen ZENODO_TOKEN) ---
ZENODO_API_TOKEN=
ZENODO_TOKEN=

# --- WWW / Recherche ---
SERPAPI_KEY=
NEWS_API_KEY=

# --- E-Mail / Outreach (ddgk_outreach_engine.py) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# --- Chat / Alerts (falls genutzt) ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# --- IBM Quantum ---
IBM_QUANTUM_TOKEN=

# --- NASA API (falls genutzt) ---
NASA_API_KEY=

# --- Supabase (falls genutzt) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# --- Ollama / Knoten ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_PI5=http://192.168.1.103:11434
OLLAMA_NOTE10=

# --- Workspace / Seed / INI-Pfad ---
ORION_SEED_SOURCE=
MASTER_ENV_INI=

# --- ORION API-Server (ddgk_api_server.py) ---
# DDGK_API_KEY=

# --- Optional: OpenAI / Anthropic (nur wenn ihr solche Clients nutzt) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Proxy / Corporate (falls nötig) ---
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=localhost,127.0.0.1
