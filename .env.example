# Kopieren nach .env im Workspace-Root (nicht committen). Alternativ: EIRA/master.env.ini
# IBM Quantum — https://quantum.ibm.com/account
IBM_QUANTUM_TOKEN=

# Ollama (optional; siehe ollama_nodes_scan.py)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_PI5=http://192.168.1.103:11434
# OLLAMA_NOTE10=http://192.168.1.XXX:11434

# ORION Seed Snapshot — wird von workspace_env + sync_orion_seed_complete.py gelesen (nach pip install -r requirements.txt)
# ORION_SEED_SOURCE=E:\ORION_SEED_COMPLETE

# Optional: eigene master.env.ini (sonst ../EIRA/master.env.ini oder ./master.env.ini)
# Nur diese Keys werden aus INI übernommen, wenn hier/OS noch leer: ORION_SEED_SOURCE, OLLAMA_HOST, OLLAMA_PI5, OLLAMA_NOTE10
# MASTER_ENV_INI=C:\Pfad\zu\master.env.ini
